<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ShowWork: AI vulnerability review</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Spectral:ital,wght@0,400;0,500;0,600;1,400&family=Source+Sans+Pro:wght@400;600&display=swap" rel="stylesheet">
<style>
  :root {
    --edgewood-red: #BB0000;
    --dark-red: #860C20;
    --dark-gold: #C8932B;
    --medium-gold: #CEB06A;
    --light-gold: #F3DFAB;
    --warm-grey: #F0EEEB;
    --dark-grey: #58595B;
    --ink: #2A2520;
    --paper: #FFFDFB;
    --line: #E2DED6;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Source Sans Pro', sans-serif;
    background: var(--warm-grey);
    color: var(--ink);
    line-height: 1.6;
    padding: 0;
  }

  .page {
    max-width: 880px;
    margin: 0 auto;
    padding: 2.5rem 1.5rem 4rem;
  }

  /* ---------- Header ---------- */
  .masthead {
    border-bottom: 3px solid var(--edgewood-red);
    padding-bottom: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .masthead .eyebrow {
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--dark-red);
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .masthead h1 {
    font-family: 'Spectral', serif;
    font-weight: 600;
    font-size: 2.1rem;
    color: var(--ink);
    letter-spacing: -0.01em;
    margin-bottom: 0.5rem;
  }

  .masthead p {
    font-size: 0.98rem;
    color: var(--dark-grey);
    max-width: 620px;
  }

  /* ---------- Form sections ---------- */
  .section {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 6px;
    padding: 1.75rem 1.75rem;
    margin-bottom: 1.5rem;
  }

  .section-label {
    font-family: 'Spectral', serif;
    font-weight: 600;
    font-size: 1.15rem;
    color: var(--ink);
    margin-bottom: 0.25rem;
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
  }

  .section-label .step {
    font-family: 'Source Sans Pro', sans-serif;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--dark-gold);
    letter-spacing: 0.08em;
  }

  .section-help {
    font-size: 0.9rem;
    color: var(--dark-grey);
    margin-bottom: 1rem;
  }

  /* ---------- Assignment type cards ---------- */
  .type-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 0.6rem;
  }

  .type-card {
    border: 1px solid var(--line);
    border-radius: 5px;
    padding: 0.85rem 1rem;
    cursor: pointer;
    background: var(--paper);
    transition: border-color 0.15s ease, background 0.15s ease;
    font-size: 0.92rem;
    text-align: left;
  }

  .type-card:hover {
    border-color: var(--medium-gold);
    background: #FCF9F2;
  }

  .type-card.selected {
    border-color: var(--edgewood-red);
    border-width: 2px;
    background: #FDF4F4;
    font-weight: 600;
  }

  .type-card .t-name {
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 0.2rem;
  }

  .type-card.selected .t-name { color: var(--dark-red); }

  .type-card .t-patterns {
    font-size: 0.78rem;
    color: var(--dark-grey);
  }

  /* ---------- Text inputs ---------- */
  label.field-label {
    display: block;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 0.35rem;
    margin-top: 1.1rem;
  }

  label.field-label:first-of-type { margin-top: 1.1rem; }

  textarea {
    width: 100%;
    min-height: 140px;
    font-family: 'Source Sans Pro', sans-serif;
    font-size: 0.95rem;
    padding: 0.75rem 0.9rem;
    border: 1px solid var(--line);
    border-radius: 5px;
    background: var(--paper);
    color: var(--ink);
    resize: vertical;
    line-height: 1.55;
  }

  textarea:focus, .type-card:focus-visible {
    outline: 2px solid var(--dark-gold);
    outline-offset: 1px;
  }

  textarea::placeholder { color: #A8A39A; }

  /* ---------- Submit ---------- */
  .submit-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 0.5rem;
  }

  button.run-btn {
    font-family: 'Source Sans Pro', sans-serif;
    font-weight: 600;
    font-size: 0.95rem;
    color: #fff;
    background: var(--edgewood-red);
    border: none;
    border-radius: 5px;
    padding: 0.7rem 1.6rem;
    cursor: pointer;
    transition: background 0.15s ease;
  }

  button.run-btn:hover:not(:disabled) { background: var(--dark-red); }

  button.run-btn:disabled {
    background: #C9A6A6;
    cursor: not-allowed;
  }

  .run-hint {
    font-size: 0.85rem;
    color: var(--dark-grey);
  }

  /* ---------- Loading ---------- */
  .loading {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.92rem;
    color: var(--dark-grey);
    padding: 0.5rem 0;
  }

  .spinner {
    width: 16px; height: 16px;
    border: 2px solid var(--line);
    border-top-color: var(--edgewood-red);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin { to { transform: rotate(360deg); } }

  /* ---------- Results ---------- */
  .results { display: none; }
  .results.visible { display: block; }

  .results-header {
    border-bottom: 3px solid var(--edgewood-red);
    padding-bottom: 1.25rem;
    margin-bottom: 1.75rem;
    margin-top: 2.5rem;
  }

  .results-header .eyebrow {
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--dark-red);
    font-weight: 600;
    margin-bottom: 0.4rem;
  }

  .results-header h2 {
    font-family: 'Spectral', serif;
    font-weight: 600;
    font-size: 1.6rem;
  }

  .results-header .meta {
    font-size: 0.88rem;
    color: var(--dark-grey);
    margin-top: 0.3rem;
  }

  .summary-box {
    background: var(--paper);
    border: 1px solid var(--line);
    border-left: 4px solid var(--dark-gold);
    border-radius: 5px;
    padding: 1.25rem 1.5rem;
    margin-bottom: 1.75rem;
    font-family: 'Spectral', serif;
    font-size: 1.02rem;
    line-height: 1.7;
    color: var(--ink);
  }

  /* Pattern review cards (margin-note style) */
  .pattern-card {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 6px;
    margin-bottom: 1rem;
    overflow: hidden;
  }

  .pattern-card.flag-high { border-left: 4px solid var(--edgewood-red); }
  .pattern-card.flag-moderate { border-left: 4px solid var(--dark-gold); }
  .pattern-card.flag-low { border-left: 4px solid #8FAE7D; }

  .pattern-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.1rem 1.4rem 0.9rem;
  }

  .pattern-name {
    font-family: 'Spectral', serif;
    font-weight: 600;
    font-size: 1.08rem;
    color: var(--ink);
  }

  .pattern-status {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.25rem 0.65rem;
    border-radius: 3px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .flag-high .pattern-status { background: #FBEAEA; color: var(--dark-red); }
  .flag-moderate .pattern-status { background: #FBF1DD; color: #8A6310; }
  .flag-low .pattern-status { background: #EBF1E5; color: #4F6B40; }

  .pattern-body {
    padding: 0 1.4rem 1.25rem;
    font-size: 0.94rem;
    color: var(--ink);
  }

  .pattern-body .diag-q {
    font-style: italic;
    color: var(--dark-grey);
    font-size: 0.88rem;
    margin-bottom: 0.6rem;
    border-bottom: 1px solid var(--line);
    padding-bottom: 0.6rem;
  }

  .pattern-body .finding { margin-bottom: 0.5rem; }
  .pattern-body .suggestion {
    margin-top: 0.6rem;
    padding-top: 0.6rem;
    border-top: 1px dashed var(--line);
    color: var(--dark-grey);
  }

  .pattern-body .suggestion strong {
    color: var(--ink);
    font-weight: 600;
  }

  .error-box {
    background: #FBEAEA;
    border: 1px solid var(--edgewood-red);
    border-radius: 5px;
    padding: 1rem 1.25rem;
    font-size: 0.9rem;
    color: var(--dark-red);
    margin-top: 1rem;
  }

  .reset-row {
    margin-top: 2rem;
    text-align: center;
  }

  .reset-row button {
    font-family: 'Source Sans Pro', sans-serif;
    font-size: 0.88rem;
    color: var(--dark-grey);
    background: none;
    border: 1px solid var(--line);
    border-radius: 5px;
    padding: 0.5rem 1.2rem;
    cursor: pointer;
  }

  .reset-row button:hover {
    border-color: var(--medium-gold);
    color: var(--ink);
  }

  @media (max-width: 600px) {
    .masthead h1 { font-size: 1.6rem; }
    .section { padding: 1.25rem; }
  }
</style>
</head>
<body>
<div class="page">

  <div class="masthead">
    <div class="eyebrow">AUPHA Art of Teaching Institute</div>
    <h1>ShowWork</h1>
    <p style="font-size: 1.02rem; color: var(--ink); margin-bottom: 0.5rem;">An AI vulnerability review for assignments</p>
    <p>Choose the type of assignment you are reviewing, then paste in your assignment prompt and rubric. The review applies the diagnostic questions most relevant to that assignment type and points to where AI could complete the task without the reasoning showing up.</p>
  </div>

  <!-- Step 1: assignment type -->
  <div class="section">
    <div class="section-label"><span class="step">Step 1</span> Assignment type</div>
    <div class="section-help">Select the format that best matches what students submit.</div>
    <div class="type-grid" id="typeGrid"></div>
  </div>

  <!-- Step 2: content -->
  <div class="section">
    <div class="section-label"><span class="step">Step 2</span> Assignment and rubric</div>
    <div class="section-help">Paste the assignment prompt as students see it, then the rubric or grading criteria.</div>

    <label class="field-label" for="assignmentText">Assignment prompt</label>
    <textarea id="assignmentText" placeholder="Paste the assignment instructions, scenario, and submission requirements as given to students."></textarea>

    <label class="field-label" for="rubricText">Rubric or grading criteria</label>
    <textarea id="rubricText" placeholder="Paste the rubric, grading rubric language, or list of criteria used to evaluate the assignment."></textarea>

    <label class="field-label" for="competencyText">Competency this assignment should demonstrate (optional)</label>
    <textarea id="competencyText" style="min-height: 70px;" placeholder="E.g. values-based leadership, financial stewardship, systems thinking. Leave blank if not applicable."></textarea>
  </div>

  <div class="submit-row">
    <button class="run-btn" id="runBtn" disabled>Review assignment</button>
    <span class="run-hint" id="runHint">Select an assignment type and paste your assignment to begin.</span>
  </div>

  <div id="loadingBox" class="loading" style="display:none;">
    <div class="spinner"></div>
    <span>Reviewing assignment against relevant diagnostic questions...</span>
  </div>

  <div id="errorBox"></div>

  <!-- Results -->
  <div class="results" id="results">
    <div class="results-header">
      <div class="eyebrow">Review results</div>
      <h2 id="resultsTitle">AI vulnerability review</h2>
      <div class="meta" id="resultsMeta"></div>
    </div>
    <div class="summary-box" id="summaryBox"></div>
    <div id="patternList"></div>
    <div class="reset-row">
      <button id="resetBtn">Start a new review</button>
    </div>
  </div>

</div>

<script>
const PATTERNS = {
  "01": { name: "Generic context", question: "Could AI answer this prompt without any organization-specific, region-specific, or population-specific knowledge?" },
  "02": { name: "Product-only deliverables", question: "Is the student's reasoning visible in what they submit, or only their conclusions?" },
  "03": { name: "Predictable prompts", question: "Does the structure of the assignment make it easier for AI to produce a strong response than for a developing student?" },
  "04": { name: "Absent rationale requirements", question: "Is the student required to justify choices and explain what alternatives were rejected?" },
  "05": { name: "Competency deliverable mismatch", question: "Does what the student submits actually demonstrate the competency you claim it demonstrates?" },
  "06": { name: "Static scenarios", question: "Does the assignment require the student to adapt to new or unexpected information?" },
  "07": { name: "Single-submission snapshot", question: "Does the assignment reveal how the student's thinking developed over time, or only what they produced at the end?" },
  "08": { name: "Verifiable-answer bias", question: "Could a correct answer exist independent of this particular student's reasoning process?" },
  "09": { name: "Decontextualized data", question: "Does the student have to identify what information is missing, unreliable, or in conflict before they can act?" },
  "10": { name: "Detachment from personal experience", question: "Does this assignment require something only this student, with this background, could meaningfully contribute?" },
  "11": { name: "Over-reliance on recall or summary", question: "Does the assignment ask the student to do something with the information beyond locating and reporting it?" }
};

const ASSIGNMENT_TYPES = [
  { id: "case_study", name: "Case study analysis", patterns: ["01","04","09","05"] },
  { id: "reflection", name: "Reflection paper", patterns: ["10","02","08"] },
  { id: "strategic_plan", name: "Strategic plan or proposal", patterns: ["03","06","05","04"] },
  { id: "discussion", name: "Discussion post", patterns: ["01","11","10"] },
  { id: "simulation", name: "Simulation or role-play", patterns: ["06","07"] },
  { id: "presentation", name: "Presentation or final report", patterns: ["02","04","05"] }
];

let selectedType = null;

const typeGrid = document.getElementById('typeGrid');
ASSIGNMENT_TYPES.forEach(t => {
  const card = document.createElement('button');
  card.className = 'type-card';
  card.type = 'button';
  card.innerHTML = `<div class="t-name">${t.name}</div><div class="t-patterns">Patterns ${t.patterns.join(', ')}</div>`;
  card.addEventListener('click', () => {
    document.querySelectorAll('.type-card').forEach(c => c.classList.remove('selected'));
    card.classList.add('selected');
    selectedType = t;
    updateRunState();
  });
  typeGrid.appendChild(card);
});

const assignmentText = document.getElementById('assignmentText');
const rubricText = document.getElementById('rubricText');
const competencyText = document.getElementById('competencyText');
const runBtn = document.getElementById('runBtn');
const runHint = document.getElementById('runHint');

function updateRunState() {
  const hasType = !!selectedType;
  const hasAssignment = assignmentText.value.trim().length > 20;
  if (hasType && hasAssignment) {
    runBtn.disabled = false;
    runHint.textContent = 'Ready to review.';
  } else {
    runBtn.disabled = true;
    if (!hasType) runHint.textContent = 'Select an assignment type and paste your assignment to begin.';
    else runHint.textContent = 'Paste your assignment prompt to continue.';
  }
}

assignmentText.addEventListener('input', updateRunState);

document.getElementById('resetBtn').addEventListener('click', () => {
  document.getElementById('results').classList.remove('visible');
  document.getElementById('errorBox').innerHTML = '';
  window.scrollTo({ top: 0, behavior: 'smooth' });
});

runBtn.addEventListener('click', runReview);

async function runReview() {
  const errorBox = document.getElementById('errorBox');
  const loadingBox = document.getElementById('loadingBox');
  const results = document.getElementById('results');

  errorBox.innerHTML = '';
  results.classList.remove('visible');
  loadingBox.style.display = 'flex';
  runBtn.disabled = true;

  const patternsToCheck = selectedType.patterns.map(id => `${id}. ${PATTERNS[id].name} — Diagnostic question: ${PATTERNS[id].question}`).join('\n');

  const systemPrompt = `You are reviewing a graduate-level healthcare administration assignment for vulnerability to AI shortcuts, meaning ways a student could produce a strong-looking submission using AI without demonstrating the reasoning, judgment, or competency the assignment is meant to assess.

You will be given an assignment prompt, a rubric, an optional target competency, and a fixed list of diagnostic patterns relevant to this assignment type. For EACH pattern in the list, assess the assignment against its diagnostic question.

Respond ONLY with valid JSON, no markdown fences, no preamble, in this exact structure:
{
  "summary": "2-3 sentence overall summary of how vulnerable this assignment is to AI shortcuts and the single highest-leverage change the instructor could make. Written in second person, plain and direct, no jargon.",
  "patterns": [
    {
      "id": "01",
      "status": "high" | "moderate" | "low",
      "finding": "1-3 sentences describing specifically, using language from THIS assignment, where it is or is not vulnerable on this pattern. Be concrete, reference actual elements of the prompt or rubric where possible.",
      "suggestion": "1-2 sentences with a specific, actionable revision the instructor could make to address this. If status is low, this can be a short note on what to preserve."
    }
  ]
}

status meanings:
- "high": this pattern represents a significant AI vulnerability in this assignment as currently written
- "moderate": some vulnerability exists but it is partial or easily mitigated
- "low": the assignment already handles this pattern well

Include exactly one object in "patterns" for each pattern ID given, in the order given. Be specific and grounded in the actual text provided. Do not be generic.`;

  const userContent = `Assignment type: ${selectedType.name}

Diagnostic patterns to assess:
${patternsToCheck}

ASSIGNMENT PROMPT:
${assignmentText.value.trim()}

RUBRIC OR GRADING CRITERIA:
${rubricText.value.trim() || '(none provided)'}

TARGET COMPETENCY:
${competencyText.value.trim() || '(none specified)'}`;

  try {
    const response = await fetch("https://api.anthropic.com/v1/messages", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        model: "claude-sonnet-4-6",
        max_tokens: 1000,
        system: systemPrompt,
        messages: [{ role: "user", content: userContent }]
      })
    });

    if (!response.ok) {
      throw new Error(`Request failed (${response.status})`);
    }

    const data = await response.json();
    const textBlock = data.content.find(b => b.type === 'text');
    if (!textBlock) throw new Error('No response received.');

    let cleaned = textBlock.text.trim().replace(/^```json\s*/i, '').replace(/^```\s*/i, '').replace(/```\s*$/i, '');
    const parsed = JSON.parse(cleaned);

    renderResults(parsed);
  } catch (err) {
    errorBox.innerHTML = `<div class="error-box">The review could not be completed (${err.message}). Try again, or check that the assignment text was pasted in.</div>`;
  } finally {
    loadingBox.style.display = 'none';
    runBtn.disabled = false;
  }
}

function renderResults(parsed) {
  document.getElementById('resultsTitle').textContent = `${selectedType.name}: ShowWork review`;
  document.getElementById('resultsMeta').textContent = `${selectedType.patterns.length} diagnostic patterns assessed`;
  document.getElementById('summaryBox').textContent = parsed.summary || '';

  const list = document.getElementById('patternList');
  list.innerHTML = '';

  const statusLabels = { high: 'Worth revising', moderate: 'Partial', low: 'Holding up' };

  parsed.patterns.forEach(p => {
    const meta = PATTERNS[p.id] || { name: 'Pattern ' + p.id, question: '' };
    const card = document.createElement('div');
    card.className = `pattern-card flag-${p.status || 'moderate'}`;
    card.innerHTML = `
      <div class="pattern-header">
        <div class="pattern-name">${meta.name}</div>
        <div class="pattern-status">${statusLabels[p.status] || p.status}</div>
      </div>
      <div class="pattern-body">
        <div class="diag-q">${meta.question}</div>
        <div class="finding">${p.finding || ''}</div>
        <div class="suggestion"><strong>Consider:</strong> ${p.suggestion || ''}</div>
      </div>
    `;
    list.appendChild(card);
  });

  document.getElementById('results').classList.add('visible');
  document.getElementById('results').scrollIntoView({ behavior: 'smooth', block: 'start' });
}
</script>
</body>
</html>
